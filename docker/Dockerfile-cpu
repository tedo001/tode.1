# syntax=docker/dockerfile:1.6
#
# tode — CPU / headless image
# ───────────────────────────
# Smallest possible image — no Tk, no torch, no ultralytics, no GPU.
# Use for headless batch annotation with .onnx weights, CI jobs, and
# server-side dataset export.
#
# Build (from repo root):
#   docker build -f docker/Dockerfile-cpu -t tode:cpu .
#
# Run:
#   docker run --rm -v $(pwd)/output:/app/output tode:cpu \
#       python -c "from core.detectors.onnx_detector import ONNXDetector; print(ONNXDetector().backend_name)"

FROM python:3.12-slim AS base

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=1 \
    PIP_DISABLE_PIP_VERSION_CHECK=1 \
    DEBIAN_FRONTEND=noninteractive \
    OPENCV_FFMPEG_CAPTURE_OPTIONS="threads;1" \
    PYTHONPATH="/app/src"

# OpenCV-headless needs libglib2.0 only — no X11, no GL.
RUN apt-get update && apt-get install --no-install-recommends -y \
        libglib2.0-0 \
        ca-certificates \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Install the headless cv2 directly rather than requirements-onnx.txt,
# which pulls opencv-python (with X11 deps).
RUN pip install --upgrade pip \
    && pip install \
        "opencv-python-headless>=4.8.0,<5.0.0" \
        "Pillow>=10.0.0" \
        "numpy>=1.24.0,<3.0.0" \
        "requests>=2.28.0" \
        "onnxruntime>=1.17.0"

COPY . .

VOLUME ["/app/output"]

CMD ["python", "-c", "print('tode:cpu — import core.* from your own script')"]
