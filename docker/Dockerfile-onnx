# syntax=docker/dockerfile:1.6
#
# tode — ONNX-only / AGPL-free image
# ──────────────────────────────────
# This variant DOES NOT install ultralytics (AGPL-3.0) or torch. It is
# intended for environments where the AGPL-3.0 license is incompatible
# with the downstream product. Only .onnx weights work in this image.
#
# Build:
#   docker build -f docker/Dockerfile-onnx -t tode:onnx .
#
# Run:
#   docker run --rm -v $(pwd)/output:/app/output tode:onnx \
#       python -c "from core.detectors.onnx_detector import ONNXDetector"
#
# License profile:
#   Python stdlib            — PSF
#   numpy, Pillow, requests  — BSD / MIT
#   opencv-python-headless   — Apache-2.0
#   onnxruntime              — MIT
#   (no ultralytics, no torch — no AGPL-3.0)

FROM python:3.12-slim AS base

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=1 \
    PIP_DISABLE_PIP_VERSION_CHECK=1 \
    DEBIAN_FRONTEND=noninteractive \
    OPENCV_FFMPEG_CAPTURE_OPTIONS="threads;1" \
    PYTHONPATH="/app/src"

RUN apt-get update && apt-get install --no-install-recommends -y \
        libglib2.0-0 \
        ca-certificates \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Use the headless cv2 to avoid the libGL dependency entirely.
RUN pip install --upgrade pip \
    && pip install \
        "opencv-python-headless>=4.8.0,<5.0.0" \
        "Pillow>=10.0.0" \
        "numpy>=1.24.0,<3.0.0" \
        "requests>=2.28.0" \
        "onnxruntime>=1.17.0"

COPY src/core    ./src/core
COPY src/models  ./src/models
COPY src/storage ./src/storage
COPY src/utils   ./src/utils
COPY weights     ./weights

VOLUME ["/app/output"]

CMD ["python", "-c", "print('tode:onnx — AGPL-free ONNX inference build')"]
